{
  "threshold": 5,
  "minTokens": 50,
  "minLines": 5,
  "reporters": ["console"],
  "format": ["typescript", "javascript"],
  "ignore": [
    "**/dist/**",
    "**/.next/**",
    "**/node_modules/**",
    "**/referencia/**",
    "**/tests/golden/**",
    "**/tests/fixtures/**",
    "**/coverage/**",
    "**/generate-object.ts",
    "**/stream-object.ts"
  ],
  "absolute": true,
  "gitignore": true,
  "exitCode": 1
}
