{
  "name": "@usetheo/sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for the Theo agent harness — same surface, local or cloud.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/usetheo/theokit-sdk#readme",
  "bugs": "https://github.com/usetheo/theokit-sdk/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/usetheo/theokit-sdk.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./cron": {
      "import": {
        "types": "./dist/cron.d.ts",
        "default": "./dist/cron.js"
      },
      "require": {
        "types": "./dist/cron.d.cts",
        "default": "./dist/cron.cjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors.d.ts",
        "default": "./dist/errors.js"
      },
      "require": {
        "types": "./dist/errors.d.cts",
        "default": "./dist/errors.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "agent",
    "agent-harness",
    "agent-sdk",
    "ai",
    "anthropic",
    "claude",
    "llm",
    "mcp",
    "openai",
    "sdk",
    "theo",
    "theokit",
    "usetheo"
  ],
  "dependencies": {
    "croner": "^9.0.0"
  }
}
