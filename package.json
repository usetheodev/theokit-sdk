{
  "name": "theokit-sdk-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter=./packages/* run build",
    "test": "pnpm --filter=./packages/* run test",
    "test:watch": "pnpm --filter=./packages/* run test:watch",
    "test:roadmap": "pnpm --filter=@usetheo/sdk exec vitest run --config vitest.roadmap.config.ts",
    "typecheck": "pnpm --filter=./packages/* run typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "validate:publint": "pnpm --filter=@usetheo/sdk exec publint",
    "validate:attw": "pnpm --filter=@usetheo/sdk exec attw --pack . --ignore-rules no-resolution",
    "quality:dead": "knip",
    "quality:cycles": "depcruise --config .dependency-cruiser.cjs packages/sdk/src",
    "quality:loc": "node tools/check-loc.mjs",
    "quality:duplication": "jscpd packages/sdk/src",
    "quality:coverage": "pnpm --filter=@usetheo/sdk exec vitest run --coverage",
    "quality:audit": "pnpm audit --prod --audit-level=high || echo '(quality:audit: high-severity advisories found — review and triage)'",
    "quality": "pnpm run quality:dead && pnpm run quality:cycles && pnpm run quality:loc && pnpm run quality:duplication",
    "quality:report": "pnpm run quality && pnpm run quality:coverage && pnpm run quality:audit",
    "validate": "pnpm run check && pnpm run typecheck && pnpm run build && pnpm run test && pnpm run validate:publint && pnpm run validate:attw && pnpm run quality",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "dependency-cruiser": "^16.10.0",
    "jscpd": "^4.0.5",
    "knip": "^5.39.0",
    "publint": "^0.3.20",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
