# Required — from @BotFather
TELEGRAM_BOT_TOKEN=

# Required — text + vision use this. OpenRouter gemini-2.0-flash-001 supports
# multimodal (text + image) on the free tier.
OPENROUTER_API_KEY=
THEOKIT_API_KEY=

# Voice transcription — at least ONE of these is required for voice messages.
# Without it, the bot replies politely "voice not configured".
#
# Option A: OpenAI Whisper. Costs ~$0.006/min. Most accurate.
OPENAI_API_KEY=
#
# Option B: Groq Whisper. Free tier, very fast.
# GROQ_API_KEY=

# Optional — web search via Tavily MCP (free tier: 1000 req/month).
# Sign up at https://tavily.com. When set, the agent gets:
#   - tavily-search: real-time web search with AI summaries
#   - tavily-extract: full-page content from any URL
#   - tavily-crawl: multi-page domain crawl
#   - tavily-map: site structure discovery
# Without it, the bot can still curl public APIs via shell tool but has no
# natural-language "search the web" capability.
TAVILY_API_KEY=

# Optional — provider fallback chain. Anthropic → OpenAI → OpenRouter.
# ANTHROPIC_API_KEY=

# Optional — lock the bot to specific user-ids (comma-separated).
TELEGRAM_ALLOWED_USERS=
