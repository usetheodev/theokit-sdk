# Notion OAuth integration. Create one at https://www.notion.so/my-integrations
# NOTION_OAUTH_CLIENT_ID=your-notion-client-id

# Provide at least ONE provider key (the agent needs an LLM to drive tool calls).
# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Without BOTH NOTION_OAUTH_CLIENT_ID and a provider key, the example runs in
# config-only mode (prints the config + exits 0). This is safe for CI.
