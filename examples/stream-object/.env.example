# Provide at least ONE of the following provider keys.
# The example picks the first one available (Anthropic > OpenAI > OpenRouter).

# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Optional: explicit THEOKIT_API_KEY (otherwise inferred from the provider key above)
# THEOKIT_API_KEY=...
