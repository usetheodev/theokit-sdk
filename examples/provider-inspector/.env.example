# THEOKIT_API_KEY is REQUIRED — `Theokit.providers.list()` (the catalog
# read) needs it to authenticate. A `theo_test_*` key serves the bundled
# fixture catalog OFFLINE, no PaaS required. Replace with a real
# THEOKIT_API_KEY + THEOKIT_API_BASE_URL once Theo PaaS is reachable.
THEOKIT_API_KEY=theo_test_inspector

# Provider key — used by `agent.providers.routes()` to render per-agent
# resolved routes. Pick one (Anthropic → OpenAI → OpenRouter is the
# auto-detect order).

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
