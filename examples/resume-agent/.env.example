# Pick the provider you want to use. The SDK auto-detects in this order:
# Anthropic → OpenAI → OpenRouter.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Any non-empty string that does NOT start with theo_test_ activates the
# real local runtime.
THEOKIT_API_KEY=user-real-example-key
