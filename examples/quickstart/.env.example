# Pick the provider you want to use. The SDK auto-detects in this order:
# Anthropic → OpenAI → OpenRouter.
#
# Uncomment and fill exactly one (or set THEOKIT_PROVIDER_PRIMARY below to
# force a specific provider).

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Any non-empty string that does NOT start with theo_test_ activates the
# real local runtime. theo_test_* is reserved for the contract-test fixture
# mode and short-circuits real LLM calls.
THEOKIT_API_KEY=user-real-example-key
