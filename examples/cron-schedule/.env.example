# A provider key is required because the cron job message now drives a
# real agent run that calls the LLM. Pick whichever provider you use.
# The SDK auto-detects in this order: Anthropic → OpenAI → OpenRouter.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

THEOKIT_API_KEY=user-real-example-key
