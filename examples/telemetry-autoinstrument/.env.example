# Provider key (required for real mode). At least ONE of:
# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Telemetry vendor keys (optional — each enables its respective auto-instrumentation):

# Langfuse (requires `pnpm add @langfuse/node @opentelemetry/api`)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com  # or self-hosted

# Sentry (requires `pnpm add @sentry/node @opentelemetry/api`; init Sentry separately)
# SENTRY_DSN=https://...

# PostHog (requires `pnpm add posthog-node @opentelemetry/api`)
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com
