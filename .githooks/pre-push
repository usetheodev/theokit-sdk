#!/usr/bin/env bash
# pre-push hook — full Tier 1 quality gates (pnpm validate).
# See .claude/quality-gates.md.

set -e

if [ -s "$HOME/.nvm/nvm.sh" ]; then
  # shellcheck source=/dev/null
  . "$HOME/.nvm/nvm.sh" >/dev/null 2>&1 || true
  nvm use --silent >/dev/null 2>&1 || true
fi

# Node 22.12+ gate (ADR D1) — SDK is validated only in its declared engine.
node_version="$(node --version 2>/dev/null || echo "v0.0.0")"
node_major="$(echo "$node_version" | sed -E 's/^v([0-9]+)\..*/\1/')"
if [ "${node_major:-0}" -lt 22 ]; then
  echo "✗ pre-push: Node ${node_version} detected, but >=v22.12.0 is required (see .nvmrc + ADR D1)."
  echo "  Run: nvm use   (respects .nvmrc)"
  exit 1
fi

echo "→ pre-push: pnpm validate (full quality gates, ~30-60s)"
echo ""

if ! pnpm -w run validate; then
  echo ""
  echo "✗ One or more hard gates failed. See .claude/quality-gates.md."
  echo "  To push anyway (emergencies only): git push --no-verify"
  exit 1
fi

echo "✓ pre-push gates passed"
